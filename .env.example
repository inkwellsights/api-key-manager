# ==============================================================================
# API Key Manager -- Environment Variables
# Copy this file to .env.local and fill in your values before running locally.
# NEVER commit .env.local (it is already excluded by .gitignore).
# ==============================================================================

# -- Supabase project URL (Project Settings > API > Project URL) ---------------
# Required at runtime on Vercel AND locally.
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co

# -- Supabase publishable (anon) key (Project Settings > API > anon/public) ----
# Safe to expose to the browser. Required at runtime on Vercel AND locally.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# -- Supabase secret key (Project Settings > API > service_role) ---------------
# Full database access -- keep this server-side only, never expose in the browser.
# Required at runtime on Vercel AND locally.
SUPABASE_SECRET_KEY=sb_secret_...

# -- AES-256-GCM encryption key for stored API keys ----------------------------
# 32 random bytes encoded as a 64-character hex string.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Required at runtime on Vercel AND locally.
API_KEY_ENC_SECRET=your-64-char-hex-string-here

# -- Direct Postgres connection (local migrations only) ------------------------
# Used ONLY to run the SQL migration files against your Supabase database.
# NOT needed by the running app on Vercel (the app uses the Supabase JS client).
#
# Supabase's direct host (db.<ref>.supabase.co) is IPv6-only. If your local
# network is IPv4-only, use the Session Pooler connection string instead:
#   postgres.<ref>@<region>-pooler.supabase.com:5432
# Find it in Supabase dashboard > Project Settings > Database > Connection string.
DATABASE_URL=postgresql://postgres.<your-project-ref>:<password>@<region>-pooler.supabase.com:5432/postgres
